# Copier vers .env et renseigner les secrets en local.
# Ne jamais commiter le fichier .env.

PORT=5000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=salle_sport_m2_cdsd
DB_USER=root
DB_PASS=

# JWT (aligné sur src/config/env.ts) — remplacer en production
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_IN_PRODUCTION
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Optionnel (non lu par app.ts aujourd’hui — pour une future restriction CORS)
# CORS_ORIGIN=http://localhost:5173
